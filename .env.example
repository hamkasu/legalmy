# Flask Configuration
FLASK_ENV=development
FLASK_APP=app:create_app
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legalmy_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_key_here

# Email Configuration
MAIL_SERVER=smtp.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password-here
MAIL_DEFAULT_SENDER=noreply@legalmy.com.my

# Railway Deployment
RAILWAY_ENV=development

# Sentry
SENTRY_DSN=https://your-sentry-dsn-here

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
